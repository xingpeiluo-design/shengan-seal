[Unit]
Description=Shengan Seal Website Backend (Flask)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/shengan-seal/backend
ExecStart=/var/www/shengan-seal/backend/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
